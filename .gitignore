# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# macOS
.DS_Store

# Editor
.vscode/
.idea/

# Backups and local notes
*.bak

# Personal debugging notes — kept locally, not for public distribution.
# (Contains specific usernames, client engagements, and home paths.)
salesforce-mcp-setup.md

# Local config (lives in ~/.sf-initial-setup-agent-config.json by default,
# but ignore if accidentally placed in the repo dir).
.sf-initial-setup-agent-config.json

# Personal Claude Code context — gitignored so personal/strategic notes
# stay local while still being read by Claude Code on session startup.
CLAUDE.md

# Claude Code per-folder local settings (tool permission allowlist, etc).
.claude/settings.local.json

# macOS double-click shortcuts — Steve's personal Claude-Code-launcher
# convenience files (e.g. "Open <agent> in Claude Code.command") stay local.
# Exception: the "Run *.command" pattern is the user-facing agent launcher
# and IS shipped — end users double-click it from Finder to run the agent.
*.command
!Run *.command

# Compiled AppleScript launcher bundle. Built locally by setup.sh from
# launcher.applescript. Not committed because (a) .app is a directory of
# binaries that doesn't diff cleanly, (b) Drive sync handles bundle
# directories inconsistently, (c) users on a different Mac should rebuild
# from source rather than running a stale or partially-synced binary.
*.app

# Internal handoff / design docs for in-flight refactors. Local-only;
# the rationale they capture should land in commit messages and the
# decisions log, not in the public repo.
HANDOFF-*.md

# Local screenshots and design assets — typically captured to attach to
# Claude Code sessions or internal docs, not for public distribution.
Screenshot *.png
Screenshot *.jpg
